# Copy this to .env (local dev) or set these in your hosting platform's dashboard.
# Never commit a real .env file.

PORT=8080

# From Google Cloud Console -> APIs & Services -> Credentials (see README "Auth setup")
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Any long random string - signs session tokens. MUST be overridden in production.
JWT_SECRET=change-me-to-something-long-and-random

# Email OTP via Brevo's HTTP API (see README "Auth setup" - free, works on
# Render's free tier unlike SMTP, which Render blocks outbound on the free plan).
BREVO_API_KEY=xkeysib-your-api-key
BREVO_SENDER_EMAIL=youraccount@gmail.com
